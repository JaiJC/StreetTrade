ST_DATABASE_URL=postgresql+asyncpg://streettrade:streettrade@localhost:5432/streettrade
ST_DATABASE_URL_SYNC=postgresql+psycopg2://streettrade:streettrade@localhost:5432/streettrade
ST_CLIP_MODEL_NAME=openai/clip-vit-base-patch32
ST_EMBEDDING_DIMENSIONS=512

# Google Maps Platform API key (Street View Static API + Places API)
# Free tier: $200/month credit. Get one at https://console.cloud.google.com
ST_GOOGLE_MAPS_API_KEY=

# Reddit API — create a "script" app at https://www.reddit.com/prefs/apps/
# Free, read-only. Only needs client_id + client_secret.
ST_REDDIT_CLIENT_ID=
ST_REDDIT_CLIENT_SECRET=
ST_REDDIT_USER_AGENT=StreetTrade/0.1 (hackathon local-biz discovery)
